   <string notr="true">QMainWindow,
QWidget#centralwidget {
    background-color: rgb(255, 255, 255);
    color: rgb(25, 28, 33);
}

QLabel {
    background-color: transparent;
    color: rgb(25, 28, 33);
}

QCheckBox {
    background-color: transparent;
    color: rgb(25, 28, 33);
    spacing: 6px;
}

QCheckBox::indicator {
    width: 14px;
    height: 14px;
    border: 1px solid rgb(120, 128, 140);
    border-radius: 3px;
    background-color: rgb(255, 255, 255);
}

QCheckBox::indicator:checked {
    background-color: rgb(0, 123, 255);
    border: 1px solid rgb(0, 110, 230);
    image: url(Resource/checkmark.svg);
}

QLineEdit {
	background-color: rgb(250, 250, 252);
    color: rgb(25, 28, 33);
    border: 1px solid rgb(200, 205, 212);
    border-radius: 6px;
    padding: 4px;
    selection-background-color: rgb(0, 123, 255);
    selection-color: white;
}

QLineEdit:focus {
    border: 1px solid rgb(0, 123, 255);
    background-color: rgb(255, 255, 255);
}

QFrame#textBrowserFrame {
    background-color: rgb(250, 250, 252);
    border: 1px solid rgb(200, 205, 212);
    border-radius: 6px;
}

QTextBrowser#textBrowser {
    background-color: transparent;
    color: rgb(25, 28, 33);
    border: none;
    selection-background-color: rgb(0, 123, 255);
    selection-color: white;
}</string>
